# Copy to .env.prod and fill in real values. Never commit .env.prod.

SCHOLARZIM_DB_USER=scholarzim
SCHOLARZIM_DB_PASSWORD=change-me-strong-db-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

SCHOLARZIM_APP_BASE_URL=https://www.scholarzim.com
SCHOLARZIM_MAIL_FROM=noreply@scholarzim.com

# SMTP (examples: Mailgun, SendGrid, Amazon SES, your host mail)
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

JAVA_OPTS=-Xms256m -Xmx768m
